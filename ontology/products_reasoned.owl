<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticweb.org/productcomparison#"
     xml:base="http://www.semanticweb.org/productcomparison"
     xmlns:pc="http://www.semanticweb.org/productcomparison#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:owl="http://www.w3.org/2002/07/owl#">

    <owl:Ontology rdf:about="http://www.semanticweb.org/productcomparison"/>

    <!-- CLASSES -->
    <owl:Class rdf:about="#Product"/>
    <owl:Class rdf:about="#Smartphone">
        <rdfs:subClassOf rdf:resource="#Product"/>
    </owl:Class>
    <owl:Class rdf:about="#Laptop">
        <rdfs:subClassOf rdf:resource="#Product"/>
    </owl:Class>
    <owl:Class rdf:about="#FlagshipSmartphone">
        <rdfs:subClassOf rdf:resource="#Smartphone"/>
    </owl:Class>
    <owl:Class rdf:about="#BudgetSmartphone">
        <rdfs:subClassOf rdf:resource="#Smartphone"/>
    </owl:Class>
    <owl:Class rdf:about="#PremiumLaptop">
        <rdfs:subClassOf rdf:resource="#Laptop"/>
    </owl:Class>
    <owl:Class rdf:about="#BudgetLaptop">
        <rdfs:subClassOf rdf:resource="#Laptop"/>
    </owl:Class>
    <owl:Class rdf:about="#Brand"/>
    <owl:Class rdf:about="#Category"/>

    <!-- OBJECT PROPERTIES -->
    <owl:ObjectProperty rdf:about="#hasBrand">
        <rdfs:domain rdf:resource="#Product"/>
        <rdfs:range rdf:resource="#Brand"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#isBetterThan">
        <rdfs:domain rdf:resource="#Product"/>
        <rdfs:range rdf:resource="#Product"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#isComparableTo">
        <rdfs:domain rdf:resource="#Product"/>
        <rdfs:range rdf:resource="#Product"/>
    </owl:ObjectProperty>

    <!-- DATA PROPERTIES -->
    <owl:DatatypeProperty rdf:about="#hasName">
        <rdfs:domain rdf:resource="#Product"/>
        <rdfs:range rdf:resource="xsd:string"/>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#hasPrice">
        <rdfs:domain rdf:resource="#Product"/>
        <rdfs:range rdf:resource="xsd:decimal"/>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#hasRAM">
        <rdfs:domain rdf:resource="#Product"/>
        <rdfs:range rdf:resource="xsd:integer"/>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#hasStorage">
        <rdfs:domain rdf:resource="#Product"/>
        <rdfs:range rdf:resource="xsd:integer"/>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#hasScore">
        <rdfs:domain rdf:resource="#Product"/>
        <rdfs:range rdf:resource="xsd:decimal"/>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#hasBatteryLife">
        <rdfs:domain rdf:resource="#Smartphone"/>
        <rdfs:range rdf:resource="xsd:decimal"/>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#hasTag">
        <rdfs:domain rdf:resource="#Product"/>
        <rdfs:range rdf:resource="xsd:string"/>
    </owl:DatatypeProperty>

    <!-- BRANDS -->
    <owl:NamedIndividual rdf:about="#Apple">
        <rdf:type rdf:resource="#Brand"/>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="#Samsung">
        <rdf:type rdf:resource="#Brand"/>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="#Google">
        <rdf:type rdf:resource="#Brand"/>
    </owl:NamedIndividual>

    <!-- PRODUCTS (Sample of 5 for testing) -->
    <owl:NamedIndividual rdf:about="#iPhone15Pro">
        <rdf:type rdf:resource="#Smartphone"/>
        <hasName>iPhone 15 Pro</hasName>
        <hasPrice rdf:datatype="xsd:decimal">999.00</hasPrice>
        <hasRAM rdf:datatype="xsd:integer">8</hasRAM>
        <hasStorage rdf:datatype="xsd:integer">256</hasStorage>
        <hasScore rdf:datatype="xsd:decimal">78.3</hasScore>
        <hasBatteryLife rdf:datatype="xsd:decimal">23.0</hasBatteryLife>
        <hasBrand rdf:resource="#Apple"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#SamsungGalaxyS24Ultra">
        <rdf:type rdf:resource="#Smartphone"/>
        <hasName>Samsung Galaxy S24 Ultra</hasName>
        <hasPrice rdf:datatype="xsd:decimal">1299.00</hasPrice>
        <hasRAM rdf:datatype="xsd:integer">12</hasRAM>
        <hasStorage rdf:datatype="xsd:integer">512</hasStorage>
        <hasScore rdf:datatype="xsd:decimal">82.1</hasScore>
        <hasBatteryLife rdf:datatype="xsd:decimal">27.0</hasBatteryLife>
        <hasBrand rdf:resource="#Samsung"/>
        <hasTag>HighPerformance</hasTag>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#iPhone14">
        <rdf:type rdf:resource="#Smartphone"/>
        <hasName>iPhone 14</hasName>
        <hasPrice rdf:datatype="xsd:decimal">599.00</hasPrice>
        <hasRAM rdf:datatype="xsd:integer">6</hasRAM>
        <hasStorage rdf:datatype="xsd:integer">128</hasStorage>
        <hasScore rdf:datatype="xsd:decimal">65.1</hasScore>
        <hasBatteryLife rdf:datatype="xsd:decimal">20.0</hasBatteryLife>
        <hasBrand rdf:resource="#Apple"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#MacBookPro16M3Pro">
        <rdf:type rdf:resource="#Laptop"/>
        <hasName>MacBook Pro 16 M3 Pro</hasName>
        <hasPrice rdf:datatype="xsd:decimal">2499.00</hasPrice>
        <hasRAM rdf:datatype="xsd:integer">18</hasRAM>
        <hasStorage rdf:datatype="xsd:integer">512</hasStorage>
        <hasScore rdf:datatype="xsd:decimal">91.2</hasScore>
        <hasBrand rdf:resource="#Apple"/>
        <hasTag>HighPerformance</hasTag>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#NokiaG42">
        <rdf:type rdf:resource="#Smartphone"/>
        <hasName>Nokia G42</hasName>
        <hasPrice rdf:datatype="xsd:decimal">199.00</hasPrice>
        <hasRAM rdf:datatype="xsd:integer">6</hasRAM>
        <hasStorage rdf:datatype="xsd:integer">128</hasStorage>
        <hasScore rdf:datatype="xsd:decimal">48.1</hasScore>
        <hasBatteryLife rdf:datatype="xsd:decimal">20.0</hasBatteryLife>
        <hasBrand rdf:resource="#Nokia"/>
        <hasTag>BestBudgetPick</hasTag>
    </owl:NamedIndividual>

    <!-- isBetterThan relationships -->
    <rdf:Description rdf:about="#iPhone15Pro">
        <isBetterThan rdf:resource="#iPhone14"/>
    </rdf:Description>

</rdf:RDF>
